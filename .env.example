# Server
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5000

# Database — MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecom?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Admin seed (used by npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Email (optional — order confirmation emails are skipped with a log if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ecom Store <no-reply@example.com>"

# Google Sheets (optional — order row append is skipped with a log if unset)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SHEET_ID=

# File storage
UPLOADS_DIR=uploads

# Logging
LOG_LEVEL=info
